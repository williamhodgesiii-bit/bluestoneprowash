# Environment variables for Bluestone Pro Wash
#
# Copy to `.env.local` for local development (that file is gitignored). In
# production, set these in Vercel → Project → Settings → Environment Variables.
#
# Everything here is `NEXT_PUBLIC_*`, meaning the value is inlined into the
# client bundle at BUILD time — so after adding or changing one in Vercel you
# must redeploy for it to take effect. Never put secrets in a NEXT_PUBLIC_ var.

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# Find it in GA4 → Admin → Data Streams → your web stream → "Measurement ID".
# Analytics only runs in production builds, so leaving this blank locally (or
# in preview) is fine — no tracking will load until it's set on Production.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Canonical production origin for SEO (canonicals, sitemap, robots, OG, JSON-LD).
# Optional — falls back to the domain hard-coded in lib/site.ts when unset.
NEXT_PUBLIC_SITE_URL=https://www.bluestoneprowash.com

# Web3Forms public access key for the quote form (safe to expose; it only lets a
# submission be delivered to the inbox tied to it). Optional — the form falls
# back to opening a prefilled email when unset.
NEXT_PUBLIC_WEB3FORMS_KEY=
